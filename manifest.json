{
  "manifest_version": 3,
  "name": "HTML Email parser",
  "description": "Find emails on the page (contact-page augmentation) | adWMG / by Ostin",
  "version": "1.0.11",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}